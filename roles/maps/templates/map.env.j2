ASA_RCON_PORT="{{ item.map_rcon_port }}"
ASA_MAX_PLAYERS="{{ item.map_max_players }}"
ASA_ADMIN_PASSWORD="{{ item.map_admin_password }}"
ASA_SERVER_PASSWORD="{{ item.map_server_password | default('') }}"
